# Environment Variables Template
# Copy this to .env for local development
# For production, set these in your deployment platform

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/party_planner_db

# Flask Secret Key (generate a random string for production)
SECRET_KEY=your_super_secret_key_here

# Optional: Set to 'production' for production environment
FLASK_ENV=production